{
  "name": "cc-island",
  "version": "0.1.0",
  "description": "macOS Dynamic Island for Claude Code — 灵动岛审批与进度展示",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc && electron-builder",
    "watch": "tsc --watch",
    "install-hooks": "ts-node scripts/install-hooks.ts",
    "remove-hooks": "ts-node scripts/remove-hooks.ts"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.5.0",
    "ts-node": "^10.9.0"
  },
  "build": {
    "appId": "com.cc-island.app",
    "productName": "Claude Island",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "hardenedRuntime": true,
      "extendInfo": {
        "LSUIElement": true
      }
    }
  }
}
