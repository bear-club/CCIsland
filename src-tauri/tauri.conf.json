{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Island Tauri PoC",
  "version": "0.1.0",
  "identifier": "com.cc-island.tauri-poc",
  "build": {
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Island",
        "width": 440,
        "height": 36,
        "visible": false,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": true,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
